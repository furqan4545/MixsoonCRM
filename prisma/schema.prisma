generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── INFLUENCERS ───────────────────────────────────────────

model Influencer {
  id             String   @id @default(cuid())
  username       String   @unique
  displayName    String?  // full name, e.g. "Emma Chen"
  profileUrl     String?
  avatarUrl      String?  // profile picture URL
  biolink        String?  // raw bio text
  bioLinkUrl     String?  // main link in bio (e.g. linktree)
  followers      Int?
  email          String?
  phone          String?
  socialLinks    String?  // JSON array of URLs
  sourceFilename String?  // which CSV file this influencer came from

  // CRM fields
  platform       String?          // TikTok, Instagram, YouTube, etc.
  engagementRate Float?           // e.g. 4.8 for 4.8%
  rate           Float?           // payment rate in USD
  language       String?          // detected from profile (e.g. "en", "ko")
  country        String?          // e.g. "US", "KR"
  pipelineStage  PipelineStage    @default(PROSPECT)
  tags           String[]         // e.g. ["skincare", "beauty", "routine"]
  notes          String?          // internal notes
  aiScore        Int?             // 0-100 AI relevance score

  savedAt        DateTime?              // when set, influencer is starred/saved by CEO
  trashedAt      DateTime?              // soft-delete: when set, influencer is in Trash queue
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  videos   Video[]
  import   Import? @relation(fields: [importId], references: [id], onDelete: SetNull)
  importId String?
  aiEvaluations InfluencerAiEvaluation[]
  emailMessages EmailMessage[]
  emailAlerts   EmailAlert[]
  activityLogs  ActivityLog[]
  campaignAssignments CampaignInfluencer[]
  approvalRequests    ApprovalRequest[]
  onboarding          InfluencerOnboarding?
  onboardingTokens    OnboardingToken[]
  contracts           Contract[]
  contentSubmissions  ContentSubmission[]
  comments            Comment[]
  analysisRuns        AnalysisRun[]
  analytics           InfluencerAnalytics?
  pics                InfluencerPic[]

  @@index([username])
  @@index([importId])
  @@index([pipelineStage])
  @@index([trashedAt])
}

enum PipelineStage {
  PROSPECT
  OUTREACH
  NEGOTIATING
  CONTRACTED
  COMPLETED
}

// ─── ACTIVITY LOG ─────────────────────────────────────────

model ActivityLog {
  id           String   @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  type         String   // "ai_score", "pipeline_change", "email_extracted", "tag_added", "note_added", "campaign_assigned", etc.
  title        String   // e.g. "AI Score assigned"
  detail       String?  // e.g. "Score: 92/100"
  createdAt    DateTime @default(now())

  @@index([influencerId])
  @@index([createdAt])
}

// ─── VIDEOS ────────────────────────────────────────────────

model Video {
  id           String   @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  username     String   // denormalized for easy lookup

  title        String?  // "signature" from Apify
  views        Int?
  bookmarks    Int?
  uploadedAt   DateTime?
  thumbnailUrl String?  // video cover image URL
  videoUrl     String?  // full TikTok video URL (https://www.tiktok.com/@user/video/123)
  tiktokId     String?  // TikTok video ID (aweme_id / itemId)
  createdAt    DateTime @default(now())

  @@index([influencerId])
  @@index([username])
}

// ─── IMPORTS ───────────────────────────────────────────────

model Import {
  id             String       @id @default(cuid())
  sourceFilename String
  rowCount       Int          @default(0)
  processedCount Int          @default(0)
  status         ImportStatus @default(PENDING)
  usernameLimit  Int          @default(-1)
  videoCount     Int          @default(20)
  saveProgress   Int          @default(0)
  saveTotal      Int          @default(0)
  errorMessage   String?
  autoDeleteAt   DateTime?    // auto-delete unactioned imports after this date
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  influencers Influencer[]
  aiFilterRuns AiFilterRun[]

  @@index([autoDeleteAt])
}

enum ImportStatus {
  PENDING
  PROCESSING
  DRAFT
  COMPLETED
  FAILED
}

// ─── AI FILTERING ───────────────────────────────────────────

model Campaign {
  id              String   @id @default(cuid())
  name            String
  targetKeywords  String[]
  avoidKeywords   String[]
  notes           String?
  strictnessDefault Int    @default(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  aiFilterRuns AiFilterRun[]

  @@index([name])
}

model AiFilterRun {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  importId      String?
  import        Import?  @relation(fields: [importId], references: [id], onDelete: SetNull)
  strictness    Int
  status        AiFilterRunStatus @default(PENDING)
  totalCount    Int @default(0)
  aiProcessedCount Int @default(0)
  reviewQueueCount Int @default(0)
  approvedCount Int @default(0)
  okishCount    Int @default(0)
  rejectedCount Int @default(0)
  failedCount   Int @default(0)
  model         String   @default("gemini-2.0-flash")
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  evaluations InfluencerAiEvaluation[]

  @@index([campaignId])
  @@index([importId])
  @@index([status])
}

model InfluencerAiEvaluation {
  id            String   @id @default(cuid())
  runId         String
  run           AiFilterRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  prefilterLabel PreFilterLabel
  score         Int?
  bucket        AiBucket
  reasons       String?
  matchedSignals String?
  riskSignals   String?
  reviewStatus  ReviewStatus @default(NOT_REVIEWED)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([runId, influencerId])
  @@index([runId])
  @@index([influencerId])
  @@index([bucket])
  @@index([reviewStatus])
}

enum AiFilterRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PreFilterLabel {
  NONE
  LIKELY_RELEVANT
  NO_KEYWORD_MATCH
  REVIEW_QUEUE
}

enum AiBucket {
  APPROVED
  OKISH
  REJECTED
  REVIEW_QUEUE
}

enum ReviewStatus {
  NOT_REVIEWED
  APPROVED_FOR_AI
  DISCARDED
  SAVED
}

// ─── NOTIFICATIONS ─────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  type       String   // e.g. "import_save", "ai_filter"
  status     String   @default("info") // "success" | "error" | "info"
  title      String
  message    String?
  read       Boolean  @default(false)
  importId   String?
  runId      String?  // AiFilterRun id when type is ai_filter
  approvalId String?  // ApprovalRequest id when type is approval
  createdAt  DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@index([status])
}

// ─── RBAC ──────────────────────────────────────────────────

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  status       UserStatus @default(PENDING)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  emailAccount EmailAccount?
  submittedApprovals ApprovalRequest[] @relation("SubmittedApprovals")
  reviewedApprovals  ApprovalRequest[] @relation("ReviewedApprovals")
  picAssignments     InfluencerPic[]
  adminSignedContracts Contract[]      @relation("AdminSignedContracts")
  contractComments     ContractComment[] @relation("ContractComments")

  @@index([roleId])
  @@index([status])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // "Admin", "PIC", "Viewer"
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
}

model Permission {
  id      String @id @default(cuid())
  feature String // e.g. "data-scraper", "csv-upload"
  action  String // e.g. "read", "write", "delete"
  roleId  String
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, feature, action])
  @@index([roleId])
}

// ─── EMAIL ──────────────────────────────────────────────

model EmailAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAddress String
  displayName  String?
  signature    String?

  smtpHost      String
  smtpPort      Int
  imapHost      String
  imapPort      Int
  username      String
  encryptedPass String

  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  messages EmailMessage[]
}

model EmailMessage {
  id        String  @id @default(cuid())
  accountId String
  account   EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  messageId String? // RFC 2822 Message-ID header for threading
  inReplyTo String? // Message-ID this is a reply to

  from    String
  to      String[]
  cc      String[]   @default([])
  subject String
  bodyHtml String?
  bodyText String?
  attachmentsJson String? // JSON array for persisted attachment metadata

  folder    EmailFolder @default(INBOX)
  isRead    Boolean     @default(false)
  isStarred Boolean     @default(false)

  sentAt     DateTime?
  receivedAt DateTime?

  influencerId String?
  influencer   Influencer? @relation(fields: [influencerId], references: [id], onDelete: SetNull)

  threadId String?

  emailAlerts EmailAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([folder])
  @@index([influencerId])
  @@index([threadId])
  @@index([isRead])
  @@index([messageId])
}

enum EmailFolder {
  INBOX
  SENT
  DRAFTS
  SPAM
  TRASH
}

// ─── MARKETING CAMPAIGNS ──────────────────────────────────

model MarketingCampaign {
  id          String   @id @default(cuid())
  name        String   // e.g. "Prime Day 2026", "Black Friday"
  description String?
  budget      Float?   // total budget in USD
  startDate   DateTime?
  endDate     DateTime?
  status      CampaignStatus @default(PLANNING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  influencers      CampaignInfluencer[]
  approvalRequests ApprovalRequest[]
  contracts        Contract[]

  @@index([status])
  @@index([name])
}

model CampaignInfluencer {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now())

  @@unique([campaignId, influencerId])
  @@index([campaignId])
  @@index([influencerId])
}

model InfluencerPic {
  id            String     @id @default(cuid())
  influencerId  String
  influencer    Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt    DateTime   @default(now())

  @@unique([influencerId, userId])
  @@index([userId])
  @@index([influencerId])
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
}

// ─── INTERNAL APPROVALS ──────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  COUNTER_OFFERED
}

enum FeedbackStatus {
  REQUESTED       // 피드백 요청
  CEO_REVIEWED    // 대표님 피드백
  APPLIED         // 피드백 반영 완료
  SPECIAL         // 특별 관리
}

enum ContractStatus {
  NEGOTIATE       // Negotiate
  APPROVED        // Approved
  DROP            // Drop
  FINAL_DROP      // Final Drop Notice
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  influencerId   String
  influencer     Influencer     @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  submittedById  String
  submittedBy    User           @relation("SubmittedApprovals", fields: [submittedById], references: [id])

  // Negotiation terms
  rate           Float
  currency       String         @default("USD")
  deliverables   String
  notes          String?

  // Pricing details (from client spreadsheet)
  videosPerBundle Int?           // 번들 당 영상 갯수
  ratePerVideo    Float?         // $/Video (VAT포함)
  totalPriceLocal Float?         // 인플루언서 제시 총 가격 (local currency)
  totalPriceUsd   Float?         // 인플루언서 제시 총 가격 ($)
  profileLink     String?        // 프로필 링크

  // Feedback
  picFeedback    String?        // 담당자 피드백
  ceoFeedback    String?        // 주업님 Feedback
  feedbackStatus FeedbackStatus @default(REQUESTED)  // 피드백 진행 사항
  contractStatus ContractStatus @default(NEGOTIATE)   // 계약현황

  // Optional campaign link
  campaignId     String?
  campaign       MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  // Review
  status         ApprovalStatus @default(PENDING)
  reviewedById   String?
  reviewedBy     User?          @relation("ReviewedApprovals", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?

  // Counter-offer
  counterRate    Float?
  counterNotes   String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([submittedById])
  @@index([status])
  @@index([influencerId])
  @@index([createdAt])
  @@index([feedbackStatus])
  @@index([contractStatus])
}

// ─── ALERTS & REMINDERS ───────────────────────────────────

enum AlertType {
  APPROVAL_PENDING          // Approval not reviewed in X days
  EMAIL_NO_REPLY_INFLUENCER // Influencer hasn't replied in X days
  EMAIL_NO_REPLY_US         // We haven't replied to influencer in X days
  CONTRACT_EXPIRING         // Contract ending within X days
  CONTENT_OVERDUE           // Content submission not received in X days
  FOLLOW_UP_REMINDER        // General follow-up reminder
}

enum AlertSeverity {
  LOW       // Info level — sidebar only
  MEDIUM    // Warning — sidebar + badge
  HIGH      // Urgent — sidebar + badge + in-app notification
  CRITICAL  // Critical — all above + email to admin
}

enum AlertEventStatus {
  ACTIVE
  DISMISSED
  RESOLVED
}

model AlertRule {
  id            String    @id @default(cuid())
  type          AlertType @unique // one rule per alert type
  thresholdDays Int       @default(3)
  enabled       Boolean   @default(true)
  templateId    String?
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  severity      AlertSeverity  @default(MEDIUM)

  // Multi-layer escalation: JSON array of { days: number, severity: string, notifyRole: string, action: string }
  // e.g. [{ "days": 3, "severity": "LOW", "notifyRole": "PIC", "action": "badge" },
  //       { "days": 7, "severity": "HIGH", "notifyRole": "ADMIN", "action": "email" },
  //       { "days": 14, "severity": "CRITICAL", "notifyRole": "ADMIN", "action": "email+badge" }]
  escalationLayers Json   @default("[]")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  events AlertEvent[]

  @@index([type])
}

model AlertEvent {
  id           String           @id @default(cuid())
  ruleId       String
  rule         AlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status       AlertEventStatus @default(ACTIVE)
  severity     AlertSeverity    @default(MEDIUM)
  escalationLevel Int           @default(0) // which layer triggered (0 = base rule)

  // Polymorphic reference — exactly one is set
  approvalId   String?
  emailId      String?          // EmailMessage id
  influencerId String?          // For quick lookups
  contractId   String?          // For contract-related alerts

  title        String
  message      String?
  daysSince    Int              // Computed at creation time

  dismissedAt  DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())

  @@unique([ruleId, approvalId])
  @@unique([ruleId, emailId])
  @@index([status])
  @@index([ruleId])
  @@index([createdAt])
  @@index([severity])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  bodyHtml  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alertRules  AlertRule[]
  emailAlerts EmailAlert[]

  @@index([name])
}

// ── Per-Email Follow-up Alerts ─────────────────────────────

enum EmailAlertStatus {
  WAITING
  TRIGGERED
  RESOLVED
  CANCELLED
}

model EmailAlert {
  id              String           @id @default(cuid())

  emailMessageId  String
  emailMessage    EmailMessage     @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  influencerId    String?
  influencer      Influencer?      @relation(fields: [influencerId], references: [id], onDelete: SetNull)

  thresholdDays   Int

  templateId      String?
  template        EmailTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)

  status          EmailAlertStatus @default(WAITING)

  triggerAt        DateTime
  triggeredAt      DateTime?
  resolvedAt       DateTime?
  cancelledAt      DateTime?
  followUpEmailId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([triggerAt])
  @@index([emailMessageId])
  @@index([influencerId])
  @@index([status, triggerAt])
}

// ─── ONBOARDING & CONTRACTS ──────────────────────────────

enum TokenType {
  ONBOARDING
  CONTRACT
  CONTENT
  PAYMENT
}

model OnboardingToken {
  id           String    @id @default(cuid())
  token        String    @unique
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  type         TokenType @default(ONBOARDING)
  contractId   String?   // For CONTRACT type tokens
  contentSubmissionId String?  // For CONTENT type tokens
  includePayment Boolean @default(false) // Whether to include payment form with content submission
  requireScode   Boolean @default(false) // Whether S-code field is required
  submissionLabel String? // Pre-set label for this submission (e.g. "1st video")
  expiresAt    DateTime
  usedAt       DateTime?
  openedAt     DateTime?  // When the influencer first opened the link
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([influencerId])
  @@index([type])
}

model InfluencerOnboarding {
  id           String   @id @default(cuid())
  influencerId String   @unique
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Bank details (account number is encrypted)
  bankName      String
  accountNumber String   // AES-256 encrypted
  accountHolder String
  bankCode      String?

  // Shipping address
  fullName     String
  addressLine1 String
  addressLine2 String?
  city         String
  postalCode   String
  country      String   @default("South Korea")

  submittedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([influencerId])
}

model ContractTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String   // HTML with {{placeholders}}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]

  @@index([name])
}

enum ContractDocStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  COMPLETED
}

model Contract {
  id             String   @id @default(cuid())
  influencerId   String
  influencer     Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaignId     String?
  campaign       MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  templateId     String?
  template       ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  filledContent    String?  // HTML content (legacy flow)
  pdfUrl           String?  // GCS URL to source PDF (DocuSign flow)
  fields           Json?    // Field placements: [{ id, type, page, x, y, width, height }]
  rate             Float?
  currency         String   @default("USD")
  deliverables     String?
  startDate        DateTime?
  endDate          DateTime?

  requireBankDetails     Boolean @default(false)
  requireShippingAddress Boolean @default(false)

  signatureDataUrl String?  // base64 of drawn/uploaded signature (influencer side)
  signedPdfUrl     String?  // GCS path of signed PDF
  signedAt         DateTime?

  // Admin counter-signature
  adminSignatureUrl String?  // base64 of admin drawn/uploaded signature or stamp
  adminSignedById   String?
  adminSignedBy     User?    @relation("AdminSignedContracts", fields: [adminSignedById], references: [id], onDelete: SetNull)
  adminSignedAt     DateTime?

  status           ContractDocStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  ContractComment[]

  @@index([influencerId])
  @@index([campaignId])
  @@index([status])
}

model ContractComment {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("ContractComments", fields: [userId], references: [id], onDelete: Cascade)
  body       String   // Comment text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([contractId])
  @@index([userId])
}

// ─── CONTENT SUBMISSIONS ─────────────────────────────────

enum ContentSubmissionStatus {
  PENDING
  SUBMITTED
  VERIFIED
  COMPLETED
}

model ContentSubmission {
  id             String   @id @default(cuid())
  influencerId   String
  influencer     Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaignId     String?

  videoLinks     Json     @default("[]") // string[] of video URLs
  notes          String?
  sCode          String?  // Internal tracking code (S-code)
  submissionLabel String? // e.g. "1st video", "Week 3", manual label

  // Payment details (optional — only when payment form is included)
  includePayment  Boolean @default(false)
  bankName        String?
  accountNumber   String?  // AES-256 encrypted
  accountHolder   String?
  bankCode        String?

  status         ContentSubmissionStatus @default(PENDING)
  submittedAt    DateTime?
  verifiedAt     DateTime?
  verifiedById   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([influencerId])
  @@index([status])
  @@index([campaignId])
}

// ─── AUDIENCE ANALYTICS ─────────────────────────────────

model Comment {
  id             String    @id @default(cuid())
  influencerId   String
  influencer     Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  videoUrl       String?
  text           String
  username       String?
  avatarUrl      String?   // commenter's profile pic (scraped for avatar sample)
  likes          Int       @default(0)
  replyCount     Int       @default(0)
  commentedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([influencerId])
}

model AnalysisRun {
  id             String            @id @default(cuid())
  influencerId   String
  influencer     Influencer        @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  status         AnalysisRunStatus @default(PENDING)
  mode           AnalysisMode      @default(HYBRID)
  batchId        String?           // links runs together in a bulk analysis batch
  commentCount   Int               @default(0)
  avatarCount    Int               @default(0)
  analyzedCount  Int               @default(0)
  progress       Int               @default(0)   // 0-100
  progressMsg    String?                         // current step message for SSE
  errorMessage   String?
  config         Json?             // snapshot of { videosToSample, commentsPerVideo, avatarsToAnalyze }
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([influencerId])
  @@index([status])
  @@index([batchId])
}

enum AnalysisRunStatus {
  PENDING
  SCRAPING_COMMENTS
  ANALYZING_COMMENTS
  ANALYZING_FACES
  COMPLETED
  FAILED
}

enum AnalysisMode {
  NLP_ONLY
  HYBRID
  FULL_VISION
}

model InfluencerAnalytics {
  id                   String   @id @default(cuid())
  influencerId         String   @unique
  influencer           Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Influencer profile (from their own profile pic via Gemini Vision)
  influencerGender     String?  // "male" | "female" | "unknown"
  influencerAgeRange   String?  // e.g. "25-34"
  influencerEthnicity  String?  // e.g. "East Asian", "South Asian", "White/Caucasian", "Black", "Latino", "Middle Eastern", "Southeast Asian", "Central Asian", "Mixed"
  influencerCountry    String?  // AI-estimated country e.g. "US|United States", "KR|South Korea"

  // Audience demographics (from NLP + commenter avatars)
  genderBreakdown      Json     // { male: %, female: %, unknown: % }
  ageBrackets          Json     // { "13-17": %, "18-24": %, "25-34": %, "35-44": %, "45+": % }
  topCountries         Json     // [{ country, countryName, percentage }]
  ethnicityBreakdown   Json?    // { "East Asian": %, "White/Caucasian": %, ... }
  topInterests         Json     // [{ category, score }]
  audienceQuality      Float?   // 0-100
  sentiment            Json?    // { positive: %, negative: %, neutral: %, humorous: % }
  commentTopics        Json?    // [{ topic, percentage, sentiment, sampleComments }]
  commentSummary       String?  // 2-3 sentence marketing summary

  // Metadata
  mode              AnalysisMode @default(HYBRID)
  confidence        Float    @default(0)  // 0-1
  commentCount      Int      @default(0)
  avatarsSampled    Int      @default(0)
  lastAnalyzedAt    DateTime @default(now())
  analysisRunId     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([influencerId])
}

model AnalysisConfig {
  id                  String   @id @default("default")
  videosToSample      Int      @default(20)
  commentsPerVideo    Int      @default(50)
  maxTotalComments    Int      @default(1000)
  avatarsToAnalyze    Int      @default(100)
  commentBatchSize    Int      @default(200)
  defaultMode         AnalysisMode @default(HYBRID)
  geminiModel         String   @default("gemini-2.0-flash")
  updatedAt           DateTime @updatedAt
}

// ─── API USAGE & BILLING ────────────────────────────────

model ApiUsageLog {
  id             String   @id @default(cuid())
  service        String   // "apify_video" | "apify_profile" | "apify_comments" | "gemini_nlp" | "gemini_vision"
  action         String   // "scrape_videos" | "scrape_profiles" | "scrape_comments" | "analyze_comments" | "analyze_face"

  importId       String?
  influencerId   String?
  analysisRunId  String?

  apifyRunId     String?
  apifyActorId   String?

  costUsd        Float    @default(0)
  inputCount     Int      @default(0)
  outputCount    Int      @default(0)
  durationMs     Int      @default(0)

  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)

  status         String   @default("success") // "success" | "failed" | "partial"
  errorMessage   String?

  createdAt      DateTime @default(now())

  @@index([service])
  @@index([importId])
  @@index([influencerId])
  @@index([createdAt])
  @@index([service, createdAt])
}
