generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── INFLUENCERS ───────────────────────────────────────────

model Influencer {
  id             String  @id @default(cuid())
  username       String  @unique
  displayName    String? // full name, e.g. "Emma Chen"
  profileUrl     String?
  avatarUrl      String? // profile picture URL
  biolink        String? // raw bio text
  bioLinkUrl     String? // main link in bio (e.g. linktree)
  followers      Int?
  email          String?
  phone          String?
  socialLinks    String? // JSON array of URLs
  sourceFilename String? // which CSV file this influencer came from

  // CRM fields
  platform       String? // TikTok, Instagram, YouTube, etc.
  engagementRate Float? // e.g. 4.8 for 4.8%
  rate           Float? // payment rate in USD
  language       String? // detected from profile (e.g. "en", "ko")
  country        String? // e.g. "US", "KR"
  pipelineStage  PipelineStage @default(PROSPECT)
  tags           String[] // e.g. ["skincare", "beauty", "routine"]
  notes          String? // internal notes
  aiScore        Int? // 0-100 AI relevance score

  savedAt   DateTime? // when set, influencer is starred/saved by CEO
  trashedAt DateTime? // soft-delete: when set, influencer is in Trash queue
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  videos              Video[]
  import              Import?                  @relation(fields: [importId], references: [id], onDelete: SetNull)
  importId            String?
  aiEvaluations       InfluencerAiEvaluation[]
  emailMessages       EmailMessage[]
  emailAlerts         EmailAlert[]
  activityLogs        ActivityLog[]
  campaignAssignments CampaignInfluencer[]
  approvalRequests    ApprovalRequest[]
  onboarding          InfluencerOnboarding?
  onboardingTokens    OnboardingToken[]
  contracts           Contract[]
  contentSubmissions  ContentSubmission[]
  comments            Comment[]
  analysisRuns        AnalysisRun[]
  analytics           InfluencerAnalytics?
  pics                InfluencerPic[]
  shipments           Shipment[]
  trackedVideos       TrackedVideo[]
  viralAlerts         ViralAlert[]
  payments            Payment[]
  contentBriefs       ContentBrief[]
  contentBriefOverrides ContentBriefOverride[]

  createdById String?
  createdBy   User?   @relation("InfluencersCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([username])
  @@index([importId])
  @@index([pipelineStage])
  @@index([trashedAt])
  @@index([createdAt])
  @@index([trashedAt, createdAt])
  @@index([createdById])
}

enum PipelineStage {
  PROSPECT
  OUTREACH
  NEGOTIATING
  CONTRACTED
  COMPLETED
}

// ─── ACTIVITY LOG ─────────────────────────────────────────

model ActivityLog {
  id           String     @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  type         String // "ai_score", "pipeline_change", "email_extracted", "tag_added", "note_added", "campaign_assigned", etc.
  title        String // e.g. "AI Score assigned"
  detail       String? // e.g. "Score: 92/100"
  createdAt    DateTime   @default(now())
  createdById  String?
  createdBy    User?      @relation("ActivityLogsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([influencerId])
  @@index([createdAt])
  @@index([createdById])
}

// ─── VIDEOS ────────────────────────────────────────────────

model Video {
  id           String     @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  username String // denormalized for easy lookup

  title        String? // "signature" from Apify
  views        Int?
  bookmarks    Int?
  uploadedAt   DateTime?
  thumbnailUrl String? // video cover image URL
  videoUrl     String? // full TikTok video URL (https://www.tiktok.com/@user/video/123)
  tiktokId     String? // TikTok video ID (aweme_id / itemId)
  createdAt    DateTime  @default(now())

  @@index([influencerId])
  @@index([username])
}

// ─── IMPORTS ───────────────────────────────────────────────

model Import {
  id             String       @id @default(cuid())
  sourceFilename String
  rowCount       Int          @default(0)
  processedCount Int          @default(0)
  status         ImportStatus @default(PENDING)
  usernameLimit  Int          @default(-1)
  videoCount     Int          @default(20)
  saveProgress   Int          @default(0)
  saveTotal      Int          @default(0)
  errorMessage   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdById    String?
  createdBy      User?        @relation("ImportsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  influencers  Influencer[]
  aiFilterRuns AiFilterRun[]

  @@index([createdById])
}

enum ImportStatus {
  PENDING
  PROCESSING
  DRAFT
  COMPLETED
  FAILED
}

// ─── AI FILTERING ───────────────────────────────────────────

model Campaign {
  id                   String   @id @default(cuid())
  name                 String
  targetKeywords       String[]
  avoidKeywords        String[]
  notes                String?
  strictnessDefault    Int      @default(50)
  // Deterministic pre-filters. Null = disabled. Evaluated before AI scoring;
  // rejections here never hit the LLM.
  maxDaysSinceLastPost Int?     @default(30) // recency: exclude if latest video older than N days
  minFollowers         Int? // follower floor
  minVideoCount        Int? // minimum videos on profile
  minTotalSaves        Int? // total bookmarks/saves across profile videos
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdById          String?
  createdBy            User?    @relation("CampaignsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  aiFilterRuns AiFilterRun[]

  @@index([name])
  @@index([createdById])
}

model AiFilterRun {
  id               String            @id @default(cuid())
  campaignId       String
  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  importId         String?
  import           Import?           @relation(fields: [importId], references: [id], onDelete: SetNull)
  strictness       Int
  status           AiFilterRunStatus @default(PENDING)
  totalCount       Int               @default(0)
  aiProcessedCount Int               @default(0)
  reviewQueueCount Int               @default(0)
  approvedCount    Int               @default(0)
  okishCount       Int               @default(0)
  rejectedCount    Int               @default(0)
  failedCount      Int               @default(0)
  model            String            @default("gemini-2.5-flash")
  errorMessage     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdById      String?
  createdBy        User?             @relation("AiFilterRunsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  evaluations InfluencerAiEvaluation[]

  @@index([campaignId])
  @@index([importId])
  @@index([status])
  @@index([createdById])
}

model InfluencerAiEvaluation {
  id             String         @id @default(cuid())
  runId          String
  run            AiFilterRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  influencerId   String
  influencer     Influencer     @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  prefilterLabel PreFilterLabel
  score          Int?
  bucket         AiBucket
  reasons        String?
  matchedSignals String?
  riskSignals    String?
  reviewStatus   ReviewStatus   @default(NOT_REVIEWED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([runId, influencerId])
  @@index([runId])
  @@index([influencerId])
  @@index([bucket])
  @@index([reviewStatus])
}

enum AiFilterRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PreFilterLabel {
  NONE
  LIKELY_RELEVANT
  NO_KEYWORD_MATCH
  REVIEW_QUEUE
  DETERMINISTIC_REJECTED
}

enum AiBucket {
  APPROVED
  OKISH
  REJECTED
  REVIEW_QUEUE
}

enum ReviewStatus {
  NOT_REVIEWED
  APPROVED_FOR_AI
  DISCARDED
  SAVED
}

// ─── NOTIFICATIONS ─────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  type       String // e.g. "import_save", "ai_filter", "payment_due"
  status     String   @default("info") // "success" | "error" | "info"
  title      String
  message    String?
  read       Boolean  @default(false)
  // Scoping. null = broadcast (all users with notifications.read see it).
  // Set = only this user sees it (fan-out to roles via createMany).
  userId     String?
  user       User?    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  importId   String?
  runId      String? // AiFilterRun id when type is ai_filter
  approvalId String? // ApprovalRequest id when type is approval
  paymentId  String? // Payment id when type is payment_due / payment_submitted
  createdAt  DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@index([status])
  @@index([userId])
}

// ─── RBAC ──────────────────────────────────────────────────

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  status       UserStatus @default(PENDING)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  emailAccount            EmailAccount?
  submittedApprovals      ApprovalRequest[] @relation("SubmittedApprovals")
  reviewedApprovals       ApprovalRequest[] @relation("ReviewedApprovals")
  picAssignments          InfluencerPic[]
  adminSignedContracts    Contract[]        @relation("AdminSignedContracts")
  contractComments        ContractComment[] @relation("ContractComments")
  shipmentsCreated        Shipment[]        @relation("ShipmentCreator")
  paymentsCreated         Payment[]         @relation("PaymentCreator")
  paymentsConfirmed       Payment[]         @relation("PaymentConfirmer")
  paymentsProofSent       Payment[]         @relation("PaymentProofSender")
  contentBriefsSent       ContentBrief[]    @relation("ContentBriefSender")
  contentBriefOverridesCreated ContentBriefOverride[] @relation("ContentBriefOverridesCreated")
  notifications           Notification[]    @relation("UserNotifications")
  onboardingTokensCreated OnboardingToken[] @relation("OnboardingTokensCreated")

  // ── Per-user ownership (Phase 1) — every owned resource points back here
  influencersCreated        Influencer[]        @relation("InfluencersCreated")
  importsCreated            Import[]            @relation("ImportsCreated")
  campaignsCreated          Campaign[]          @relation("CampaignsCreated")
  contractsCreated          Contract[]          @relation("ContractsCreated")
  contractTemplatesCreated  ContractTemplate[]  @relation("ContractTemplatesCreated")
  contentSubmissionsCreated ContentSubmission[] @relation("ContentSubmissionsCreated")
  emailTemplatesCreated     EmailTemplate[]     @relation("EmailTemplatesCreated")
  emailAlertsCreated        EmailAlert[]        @relation("EmailAlertsCreated")
  alertRulesCreated         AlertRule[]         @relation("AlertRulesCreated")
  marketingCampaignsCreated MarketingCampaign[] @relation("MarketingCampaignsCreated")
  aiFilterRunsCreated       AiFilterRun[]       @relation("AiFilterRunsCreated")
  analysisRunsCreated       AnalysisRun[]       @relation("AnalysisRunsCreated")
  viralAlertConfigsCreated  ViralAlertConfig[]  @relation("ViralAlertConfigsCreated")
  budgetConfigsCreated      BudgetConfig[]      @relation("BudgetConfigsCreated")
  scrapingConfigsCreated    ScrapingConfig[]    @relation("ScrapingConfigsCreated")
  analysisConfigsCreated    AnalysisConfig[]    @relation("AnalysisConfigsCreated")
  activityLogsCreated       ActivityLog[]       @relation("ActivityLogsCreated")
  trackedVideosCreated      TrackedVideo[]      @relation("TrackedVideosCreated")
  productsCreated           Product[]           @relation("ProductsCreated")

  // ── Resource sharing (Phase 1)
  sharedResources       ResourceShare[] @relation("ShareRecipient")
  resourceSharesCreated ResourceShare[] @relation("ShareGrantor")

  @@index([roleId])
  @@index([status])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // "Admin", "PIC", "Viewer"
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
}

model Permission {
  id      String @id @default(cuid())
  feature String // e.g. "data-scraper", "csv-upload"
  action  String // e.g. "read", "write", "delete"
  roleId  String
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, feature, action])
  @@index([roleId])
}

// ─── EMAIL ──────────────────────────────────────────────

model EmailAccount {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAddress String
  displayName  String?
  signature    String?

  smtpHost      String
  smtpPort      Int
  imapHost      String
  imapPort      Int
  username      String
  encryptedPass String

  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  messages EmailMessage[]
}

model EmailMessage {
  id        String       @id @default(cuid())
  accountId String
  account   EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  messageId String? // RFC 2822 Message-ID header for threading
  inReplyTo String? // Message-ID this is a reply to

  from            String
  to              String[]
  cc              String[] @default([])
  subject         String
  bodyHtml        String?
  bodyText        String?
  attachmentsJson String? // JSON array for persisted attachment metadata

  folder    EmailFolder @default(INBOX)
  isRead    Boolean     @default(false)
  isStarred Boolean     @default(false)

  sentAt     DateTime?
  receivedAt DateTime?

  influencerId String?
  influencer   Influencer? @relation(fields: [influencerId], references: [id], onDelete: SetNull)

  threadId String?

  emailAlerts EmailAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@index([folder])
  @@index([influencerId])
  @@index([threadId])
  @@index([isRead])
  @@index([messageId])
}

enum EmailFolder {
  INBOX
  SENT
  DRAFTS
  SPAM
  TRASH
}

// ─── MARKETING CAMPAIGNS ──────────────────────────────────

model MarketingCampaign {
  id          String         @id @default(cuid())
  name        String // e.g. "Prime Day 2026", "Black Friday"
  description String?
  budget      Float? // total budget in USD
  startDate   DateTime?
  endDate     DateTime?
  status      CampaignStatus @default(PLANNING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Default content brief for this campaign/product. Used as the starting point
  // when sending a brief to any influencer; can be overridden per-influencer.
  contentBriefBody      String? // key messages / what to post about
  contentBriefHowToPost String? // technical posting rules — format, length, mentions, etc.
  contentBriefHashtags  String[] @default([])

  influencers      CampaignInfluencer[]
  approvalRequests ApprovalRequest[]
  contracts        Contract[]
  shipments        Shipment[]
  trackedVideos    TrackedVideo[]
  payments         Payment[]
  contentBriefs    ContentBrief[]
  contentBriefOverrides ContentBriefOverride[]

  createdById String?
  createdBy   User?   @relation("MarketingCampaignsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([name])
  @@index([createdById])
}

// Per-influencer override of a campaign's default content brief. When sending
// the brief to influencer X for campaign Y, we look here first; fall back to
// the campaign's default if no row exists.
model ContentBriefOverride {
  id                  String            @id @default(cuid())
  marketingCampaignId String
  marketingCampaign   MarketingCampaign @relation(fields: [marketingCampaignId], references: [id], onDelete: Cascade)
  influencerId        String
  influencer          Influencer        @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  body                String
  howToPost           String?
  hashtags            String[]          @default([])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  createdById         String?
  createdBy           User?             @relation("ContentBriefOverridesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([marketingCampaignId, influencerId])
  @@index([influencerId])
}

// One row per "send" event — snapshots exactly what was emailed (audit log).
// One-way: no influencer response, no token, no public page.
model ContentBrief {
  id                  String            @id @default(cuid())
  marketingCampaignId String
  marketingCampaign   MarketingCampaign @relation(fields: [marketingCampaignId], references: [id], onDelete: Cascade)
  influencerId        String
  influencer          Influencer        @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Snapshot of what was emailed — every column is what the influencer received.
  bodySnapshot      String
  howToPostSnapshot String?
  hashtagsSnapshot  String[]  @default([])
  uploadDate        DateTime? // the date WE told them to post
  notes             String?   // per-send optional free text (anything extra)

  sentByUserId String?
  sentByUser   User?    @relation("ContentBriefSender", fields: [sentByUserId], references: [id], onDelete: SetNull)
  sentAt       DateTime @default(now())

  @@index([influencerId])
  @@index([marketingCampaignId])
  @@index([sentAt])
}

model CampaignInfluencer {
  id           String            @id @default(cuid())
  campaignId   String
  campaign     MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencerId String
  influencer   Influencer        @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  assignedAt   DateTime          @default(now())

  @@unique([campaignId, influencerId])
  @@index([campaignId])
  @@index([influencerId])
}

model InfluencerPic {
  id           String     @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@unique([influencerId, userId])
  @@index([userId])
  @@index([influencerId])
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
}

// ─── INTERNAL APPROVALS ──────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  COUNTER_OFFERED
}

enum FeedbackStatus {
  REQUESTED // 피드백 요청
  CEO_REVIEWED // 대표님 피드백
  APPLIED // 피드백 반영 완료
  SPECIAL // 특별 관리
}

enum ContractStatus {
  NEGOTIATE // Negotiate
  APPROVED // Approved
  DROP // Drop
  FINAL_DROP // Final Drop Notice
}

model ApprovalRequest {
  id           String     @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  submittedById String
  submittedBy   User   @relation("SubmittedApprovals", fields: [submittedById], references: [id])

  // Negotiation terms
  rate         Float
  currency     String  @default("USD")
  deliverables String
  notes        String?

  // Pricing details (from client spreadsheet)
  videosPerBundle Int? // 번들 당 영상 갯수
  ratePerVideo    Float? // $/Video (VAT포함)
  totalPriceLocal Float? // 인플루언서 제시 총 가격 (local currency)
  totalPriceUsd   Float? // 인플루언서 제시 총 가격 ($)
  profileLink     String? // 프로필 링크

  // Feedback
  picFeedback    String? // 담당자 피드백
  ceoFeedback    String? // 주업님 Feedback
  feedbackStatus FeedbackStatus @default(REQUESTED) // 피드백 진행 사항
  contractStatus ContractStatus @default(NEGOTIATE) // 계약현황

  // Optional campaign link
  campaignId String?
  campaign   MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  // Review
  status       ApprovalStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?          @relation("ReviewedApprovals", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  // Counter-offer
  counterRate  Float?
  counterNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submittedById])
  @@index([status])
  @@index([influencerId])
  @@index([createdAt])
  @@index([feedbackStatus])
  @@index([contractStatus])
}

// ─── ALERTS & REMINDERS ───────────────────────────────────

enum AlertType {
  APPROVAL_PENDING // Approval not reviewed in X days
  EMAIL_NO_REPLY_INFLUENCER // Influencer hasn't replied in X days
  EMAIL_NO_REPLY_US // We haven't replied to influencer in X days
  CONTRACT_EXPIRING // Contract ending within X days
  CONTENT_OVERDUE // Content submission not received in X days
  FOLLOW_UP_REMINDER // General follow-up reminder
  VIRAL_VIDEO // Video crossed viral threshold
}

enum AlertSeverity {
  LOW // Info level — sidebar only
  MEDIUM // Warning — sidebar + badge
  HIGH // Urgent — sidebar + badge + in-app notification
  CRITICAL // Critical — all above + email to admin
}

enum AlertEventStatus {
  ACTIVE
  DISMISSED
  RESOLVED
}

model AlertRule {
  id            String         @id @default(cuid())
  type          AlertType      @unique // one rule per alert type
  thresholdDays Int            @default(3)
  enabled       Boolean        @default(true)
  templateId    String?
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  severity      AlertSeverity  @default(MEDIUM)

  // Multi-layer escalation: JSON array of { days: number, severity: string, notifyRole: string, action: string }
  // e.g. [{ "days": 3, "severity": "LOW", "notifyRole": "PIC", "action": "badge" },
  //       { "days": 7, "severity": "HIGH", "notifyRole": "ADMIN", "action": "email" },
  //       { "days": 14, "severity": "CRITICAL", "notifyRole": "ADMIN", "action": "email+badge" }]
  escalationLayers Json @default("[]")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("AlertRulesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  events AlertEvent[]

  @@index([type])
  @@index([createdById])
}

model AlertEvent {
  id              String           @id @default(cuid())
  ruleId          String
  rule            AlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  status          AlertEventStatus @default(ACTIVE)
  severity        AlertSeverity    @default(MEDIUM)
  escalationLevel Int              @default(0) // which layer triggered (0 = base rule)

  // Polymorphic reference — exactly one is set
  approvalId   String?
  emailId      String? // EmailMessage id
  influencerId String? // For quick lookups
  contractId   String? // For contract-related alerts

  title     String
  message   String?
  daysSince Int // Computed at creation time

  dismissedAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([ruleId, approvalId])
  @@unique([ruleId, emailId])
  @@index([status])
  @@index([ruleId])
  @@index([createdAt])
  @@index([severity])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String
  bodyHtml    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("EmailTemplatesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  alertRules  AlertRule[]
  emailAlerts EmailAlert[]

  @@index([name])
  @@index([createdById])
}

// ── Per-Email Follow-up Alerts ─────────────────────────────

enum EmailAlertStatus {
  WAITING
  TRIGGERED
  RESOLVED
  CANCELLED
}

model EmailAlert {
  id String @id @default(cuid())

  emailMessageId String
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  influencerId String?
  influencer   Influencer? @relation(fields: [influencerId], references: [id], onDelete: SetNull)

  thresholdDays Int

  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  status EmailAlertStatus @default(WAITING)

  triggerAt       DateTime
  triggeredAt     DateTime?
  resolvedAt      DateTime?
  cancelledAt     DateTime?
  followUpEmailId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("EmailAlertsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([triggerAt])
  @@index([emailMessageId])
  @@index([influencerId])
  @@index([status, triggerAt])
  @@index([createdById])
}

// ─── ONBOARDING & CONTRACTS ──────────────────────────────

enum TokenType {
  ONBOARDING
  CONTRACT
  CONTENT
  PAYMENT
}

model OnboardingToken {
  id                  String     @id @default(cuid())
  token               String     @unique
  influencerId        String
  influencer          Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  type                TokenType  @default(ONBOARDING)
  contractId          String? // For CONTRACT type tokens
  contentSubmissionId String? // For CONTENT type tokens
  includePayment      Boolean    @default(false) // Whether to include payment form with content submission
  requireScode        Boolean    @default(false) // Whether S-code field is required
  submissionLabel     String? // Pre-set label for this submission (e.g. "1st video")
  expiresAt           DateTime
  usedAt              DateTime?
  openedAt            DateTime? // When the influencer first opened the link
  createdAt           DateTime   @default(now())
  createdById         String? // User who sent the form — used to route submission notifications back
  createdBy           User?      @relation("OnboardingTokensCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([influencerId])
  @@index([type])
  @@index([createdById])
}

model InfluencerOnboarding {
  id           String     @id @default(cuid())
  influencerId String     @unique
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Bank details (account number is encrypted)
  bankName      String
  accountNumber String // AES-256 encrypted
  accountHolder String
  bankCode      String?

  // Shipping address
  fullName     String
  addressLine1 String
  addressLine2 String?
  city         String
  postalCode   String
  country      String  @default("South Korea")

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([influencerId])
}

model ContractTemplate {
  id          String   @id @default(cuid())
  name        String
  content     String // HTML with {{placeholders}}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("ContractTemplatesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  contracts Contract[]

  @@index([name])
  @@index([createdById])
}

enum ContractDocStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  COMPLETED
}

model Contract {
  id           String             @id @default(cuid())
  influencerId String
  influencer   Influencer         @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaignId   String?
  campaign     MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  templateId   String?
  template     ContractTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  filledContent String? // HTML content (legacy flow)
  pdfUrl        String? // GCS URL to source PDF (DocuSign flow)
  fields        Json? // Field placements: [{ id, type, page, x, y, width, height }]
  rate          Float?
  currency      String    @default("USD")
  deliverables  String?
  startDate     DateTime?
  endDate       DateTime?

  requireBankDetails     Boolean @default(false)
  requireShippingAddress Boolean @default(false)

  signatureDataUrl String? // base64 of drawn/uploaded signature (influencer side)
  signedPdfUrl     String? // GCS path of signed PDF
  signedAt         DateTime?

  // Admin counter-signature
  adminSignatureUrl String? // base64 of admin drawn/uploaded signature or stamp
  adminSignedById   String?
  adminSignedBy     User?     @relation("AdminSignedContracts", fields: [adminSignedById], references: [id], onDelete: SetNull)
  adminSignedAt     DateTime?

  status ContractDocStatus @default(DRAFT)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("ContractsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  comments ContractComment[]

  @@index([influencerId])
  @@index([campaignId])
  @@index([status])
  @@index([createdById])
}

model ContractComment {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("ContractComments", fields: [userId], references: [id], onDelete: Cascade)
  body       String // Comment text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([contractId])
  @@index([userId])
}

// ─── CONTENT SUBMISSIONS ─────────────────────────────────

enum ContentSubmissionStatus {
  PENDING
  SUBMITTED
  VERIFIED
  COMPLETED
}

model ContentSubmission {
  id           String     @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaignId   String?

  videoLinks      Json    @default("[]") // string[] of video URLs
  videoFiles      Json    @default("[]") // [{ gcsPath, name, size, type }] uploaded directly to our bucket
  notes           String?
  sCode           String? // Internal tracking code (S-code)
  submissionLabel String? // e.g. "1st video", "Week 3", manual label

  // Payment details (optional — only when payment form is included)
  includePayment Boolean @default(false)
  bankName       String?
  accountNumber  String? // AES-256 encrypted
  accountHolder  String?
  bankCode       String?

  status       ContentSubmissionStatus @default(PENDING)
  submittedAt  DateTime?
  verifiedAt   DateTime?
  verifiedById String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("ContentSubmissionsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([influencerId])
  @@index([status])
  @@index([campaignId])
  @@index([createdById])
}

// ─── AUDIENCE ANALYTICS ─────────────────────────────────

model Comment {
  id           String     @id @default(cuid())
  influencerId String
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  videoUrl     String?
  text         String
  username     String?
  avatarUrl    String? // commenter's profile pic (scraped for avatar sample)
  likes        Int        @default(0)
  replyCount   Int        @default(0)
  commentedAt  DateTime?
  createdAt    DateTime   @default(now())

  @@index([influencerId])
}

model AnalysisRun {
  id            String            @id @default(cuid())
  influencerId  String
  influencer    Influencer        @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  status        AnalysisRunStatus @default(PENDING)
  mode          AnalysisMode      @default(HYBRID)
  batchId       String? // links runs together in a bulk analysis batch
  commentCount  Int               @default(0)
  avatarCount   Int               @default(0)
  analyzedCount Int               @default(0)
  progress      Int               @default(0) // 0-100
  progressMsg   String? // current step message for SSE
  errorMessage  String?
  config        Json? // snapshot of { videosToSample, commentsPerVideo, avatarsToAnalyze }
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdById   String?
  createdBy     User?             @relation("AnalysisRunsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([influencerId])
  @@index([status])
  @@index([batchId])
  @@index([createdById])
}

enum AnalysisRunStatus {
  PENDING
  SCRAPING_COMMENTS
  ANALYZING_COMMENTS
  ANALYZING_FACES
  COMPLETED
  FAILED
}

enum AnalysisMode {
  NLP_ONLY
  HYBRID
  FULL_VISION
}

model InfluencerAnalytics {
  id           String     @id @default(cuid())
  influencerId String     @unique
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // Influencer profile (from their own profile pic via Gemini Vision)
  influencerGender    String? // "male" | "female" | "unknown"
  influencerAgeRange  String? // e.g. "25-34"
  influencerEthnicity String? // e.g. "East Asian", "South Asian", "White/Caucasian", "Black", "Latino", "Middle Eastern", "Southeast Asian", "Central Asian", "Mixed"
  influencerCountry   String? // AI-estimated country e.g. "US|United States", "KR|South Korea"

  // Audience demographics (from NLP + commenter avatars)
  genderBreakdown    Json // { male: %, female: %, unknown: % }
  ageBrackets        Json // { "13-17": %, "18-24": %, "25-34": %, "35-44": %, "45+": % }
  topCountries       Json // [{ country, countryName, percentage }]
  ethnicityBreakdown Json? // { "East Asian": %, "White/Caucasian": %, ... }
  topInterests       Json // [{ category, score }]
  audienceQuality    Float? // 0-100
  sentiment          Json? // { positive: %, negative: %, neutral: %, humorous: % }
  commentTopics      Json? // [{ topic, percentage, sentiment, sampleComments }]
  commentSummary     String? // 2-3 sentence marketing summary

  // Metadata
  mode           AnalysisMode @default(HYBRID)
  confidence     Float        @default(0) // 0-1
  commentCount   Int          @default(0)
  avatarsSampled Int          @default(0)
  lastAnalyzedAt DateTime     @default(now())
  analysisRunId  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([influencerId])
}

model AnalysisConfig {
  id               String       @id @default("default")
  videosToSample   Int          @default(20)
  commentsPerVideo Int          @default(50)
  avatarsToAnalyze Int          @default(100)
  commentBatchSize Int          @default(200)
  defaultMode      AnalysisMode @default(HYBRID)
  geminiModel      String       @default("gemini-2.5-flash")
  updatedAt        DateTime     @updatedAt
  createdById      String?
  createdBy        User?        @relation("AnalysisConfigsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById])
}

// Global scraping settings — applies platform-wide to all Apify calls
// (video scraper, profile scraper, comment scraper, etc).
model ScrapingConfig {
  id          String   @id @default("default")
  concurrency Int      @default(10)
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("ScrapingConfigsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById])
}

// ─── API USAGE & BILLING ────────────────────────────────

model ApiUsageLog {
  id      String @id @default(cuid())
  service String // "apify_video" | "apify_profile" | "apify_comments" | "gemini_nlp" | "gemini_vision"
  action  String // "scrape_videos" | "scrape_profiles" | "scrape_comments" | "analyze_comments" | "analyze_face"

  importId      String?
  influencerId  String?
  analysisRunId String?

  apifyRunId   String?
  apifyActorId String?

  costUsd     Float @default(0)
  inputCount  Int   @default(0)
  outputCount Int   @default(0)
  durationMs  Int   @default(0)

  inputTokens  Int @default(0)
  outputTokens Int @default(0)

  status       String  @default("success") // "success" | "failed" | "partial"
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([service])
  @@index([importId])
  @@index([influencerId])
  @@index([createdAt])
  @@index([service, createdAt])
}

// ─── BUDGET CONFIG ────────────────────────────────────────

model BudgetConfig {
  id                String    @id @default("default")
  monthlyCapUsd     Float     @default(0) // 0 = no cap set
  isBlocked         Boolean   @default(false) // true = all external API calls blocked
  blockedAt         DateTime?
  blockedByUserId   String?
  unblockedAt       DateTime?
  unblockedByUserId String?
  blockReason       String? // "budget_exceeded" | "manual"
  gcpManualCostUsd  Float     @default(0) // admin enters monthly GCP cost
  gcpCostUpdatedAt  DateTime?
  updatedAt         DateTime  @updatedAt
  createdById       String?
  createdBy         User?     @relation("BudgetConfigsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById])
}

// ─── INVENTORY & SHIPPING ─────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  description String?
  category    String?
  imageUrl    String?
  quantity    Int      @default(0) // total stock
  reserved    Int      @default(0) // assigned but not yet delivered
  unitCost    Float? // cost per unit in USD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("ProductsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  shipments Shipment[]

  @@index([sku])
  @@index([category])
  @@index([createdById])
}

enum ShippingCarrier {
  DHL
  UPS
  FEDEX
  EMS
  OTHER
}

enum ShipmentStatus {
  PENDING // product assigned, not shipped yet
  SHIPPED // carrier picked up
  IN_TRANSIT // in transit
  DELIVERED // delivered to influencer
  RETURNED // returned/undeliverable
  FAILED // shipment failed
}

model Shipment {
  id           String             @id @default(cuid())
  productId    String
  product      Product            @relation(fields: [productId], references: [id])
  influencerId String
  influencer   Influencer         @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaignId   String?
  campaign     MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  quantity         Int             @default(1) // number of units in this shipment
  carrier          ShippingCarrier @default(OTHER)
  trackingNumber   String?
  trackingUrl      String? // auto-generated clickable link
  status           ShipmentStatus  @default(PENDING)
  shippingAddress  Json? // snapshot of influencer address at creation
  lastTrackingData Json? // cached carrier API response
  lastTrackedAt    DateTime?
  notes            String?

  shippedAt   DateTime?
  deliveredAt DateTime?

  createdById String?
  createdBy   User?    @relation("ShipmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([influencerId])
  @@index([productId])
  @@index([campaignId])
  @@index([status])
  @@index([trackingNumber])
}

// ─── TIKTOK PERFORMANCE TRACKING ──────────────────────────

model TrackedVideo {
  id                  String             @id @default(cuid())
  videoUrl            String             @unique // TikTok video URL
  tiktokId            String? // extracted video ID
  influencerId        String
  influencer          Influencer         @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaignId          String?
  campaign            MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contentSubmissionId String?

  title        String?
  thumbnailUrl String?

  // Current stats (updated on each refresh)
  currentViews    Int @default(0)
  currentLikes    Int @default(0)
  currentComments Int @default(0)
  currentSaves    Int @default(0)
  currentShares   Int @default(0)

  isTracking    Boolean   @default(true)
  lastTrackedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?
  createdBy     User?     @relation("TrackedVideosCreated", fields: [createdById], references: [id], onDelete: SetNull)

  snapshots   VideoSnapshot[]
  viralAlerts ViralAlert[]

  @@index([influencerId])
  @@index([isTracking])
  @@index([campaignId])
  @@index([createdById])
}

model VideoSnapshot {
  id             String       @id @default(cuid())
  trackedVideoId String
  trackedVideo   TrackedVideo @relation(fields: [trackedVideoId], references: [id], onDelete: Cascade)

  views    Int @default(0)
  likes    Int @default(0)
  comments Int @default(0)
  saves    Int @default(0)
  shares   Int @default(0)

  recordedAt DateTime // date of this snapshot

  @@unique([trackedVideoId, recordedAt])
  @@index([trackedVideoId])
  @@index([recordedAt])
}

enum ViralAlertStatus {
  ACTIVE
  DISMISSED
  ACKNOWLEDGED
}

model ViralAlert {
  id             String       @id @default(cuid())
  trackedVideoId String
  trackedVideo   TrackedVideo @relation(fields: [trackedVideoId], references: [id], onDelete: Cascade)
  influencerId   String
  influencer     Influencer   @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  metric       String // "views", "likes", "comments", "saves", "shares"
  threshold    Int // what threshold was crossed
  valueAtAlert Int // actual value when alert fired
  status       ViralAlertStatus @default(ACTIVE)

  createdAt   DateTime  @default(now())
  dismissedAt DateTime?

  @@index([trackedVideoId])
  @@index([influencerId])
  @@index([status])
}

model ViralAlertConfig {
  id                String   @id @default("default")
  viewsThreshold    Int      @default(100000)
  likesThreshold    Int      @default(10000)
  commentsThreshold Int      @default(5000)
  savesThreshold    Int      @default(5000)
  sharesThreshold   Int      @default(5000)
  pollIntervalHours Int      @default(5) // how often cron refreshes stats (hours)
  enabled           Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  createdById       String?
  createdBy         User?    @relation("ViralAlertConfigsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById])
}

// ─── PAYMENT MANAGEMENT ──────────────────────────────────

enum PaymentStatus {
  PENDING // payment created, not yet processed
  PROCESSING // being processed by finance
  SENT // payment sent to influencer
  RECEIVED // influencer confirmed receipt
  FAILED // payment failed
}

model Payment {
  id           String             @id @default(cuid())
  influencerId String
  influencer   Influencer         @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  campaignId   String?
  campaign     MarketingCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  amount   Float
  currency String        @default("KRW")
  status   PaymentStatus @default(PENDING)

  // Bank details snapshot (copied from InfluencerOnboarding at creation)
  bankName      String?
  accountNumber String? // AES-256 encrypted
  accountHolder String?
  bankCode      String?

  invoiceNumber String?
  notes         String?

  paidAt      DateTime? // when status becomes SENT
  confirmedAt DateTime? // when status becomes RECEIVED

  // Self-confirmation by influencer (clicks the link in the "Sent" email).
  // Issued when status -> SENT; consumed when influencer hits the public route.
  confirmToken          String?   @unique
  confirmTokenExpiresAt DateTime?

  // Who confirmed receipt. confirmedByUserId is set ONLY when an internal user
  // force-marks the payment as RECEIVED (force-override path). If null while
  // confirmedAt is set, the influencer self-confirmed via the email link.
  // confirmedByEmail is a denormalized snapshot for display — the team member's
  // email on force-mark, or the influencer's email on self-confirm.
  confirmedByUserId String?
  confirmedByUser   User?   @relation("PaymentConfirmer", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  confirmedByEmail  String?

  // Proof-of-payment workflow. confirmToken (above) doubles as the auth for the
  // public "request proof" page — one signed link covers both flows.
  proofRequestedAt  DateTime?         // when influencer clicked the request link
  proofSentAt       DateTime?         // when team uploaded and sent the proof
  proofSentMessage  String?           // optional note from team in the proof email
  proofFiles        Json?             // [{ gcsPath, name, size, type }]
  proofSentByUserId String?
  proofSentByUser   User?             @relation("PaymentProofSender", fields: [proofSentByUserId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?    @relation("PaymentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([influencerId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
}

// ─── PER-USER ISOLATION (Phase 1) ─────────────────────────

// Resource-level sharing. Lets a user grant access to one of their owned
// resources (e.g. an Import, a Campaign, a Contract) to another user.
model ResourceShare {
  id           String   @id @default(cuid())
  resourceType String // "Import" | "Campaign" | "Influencer" | "Contract" | etc.
  resourceId   String
  userId       String // recipient
  user         User     @relation("ShareRecipient", fields: [userId], references: [id], onDelete: Cascade)
  permission   String   @default("read") // "read" | "write" | "admin"
  sharedById   String? // who granted the share
  sharedBy     User?    @relation("ShareGrantor", fields: [sharedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@unique([resourceType, resourceId, userId])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([sharedById])
}

// Global system-level settings. Currently used to flag whether admins
// see-everything or are isolated like other users.
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
